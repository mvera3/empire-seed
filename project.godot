; Engine configuration file.
; Empire Seed — Phase 1 (Core Builder)
; Generated for Godot 4.7

config_version=5

[application]

config/name="Empire Seed"
config/description="Offline pixel civilization builder — Arcanoire Studio"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/GameState.gd"
SaveManager="*res://scripts/SaveManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.76, 0.8, 0.85, 1)
